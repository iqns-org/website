#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "${SCRIPT_DIR}/.."

current_branch="$(git rev-parse --abbrev-ref HEAD)"
if [ "${current_branch}" != "main" ]; then
  echo "Error: release must be run from the main branch, currently on '${current_branch}'." >&2
  exit 1
fi

git_status="$(git status --porcelain)"
if [ -n "${git_status}" ]; then
  dirty="$(printf '%s\n' "${git_status}" | grep -vE '^\?\? bin/release$' || true)"
  if [ -n "${dirty}" ]; then
    echo "Error: working tree is dirty. Commit or stash changes before running release." >&2
    git status --short
    exit 1
  fi
  echo "Warning: untracked bin/release detected; continuing because only the release helper is untracked."
fi

echo "Starting release from $(pwd)"

npm version patch --no-git-tag-version

VERSION="$(node -e "process.stdout.write(require('./package.json').version)")"
if [ -z "${VERSION}" ]; then
  echo "Error: could not read version from package.json" >&2
  exit 1
fi

echo "Bumped version to ${VERSION}"

echo "Running test suite..."
npm run test

echo "Running translation script..."
before_translator="$(git diff --name-only | sort)"
npm run translator -- --force

translator_changes="$(comm -13 <(printf '%s\n' "${before_translator}" | sed '/^$/d') <(git diff --name-only | sort) | sed '/^$/d')"
if [ -n "${translator_changes}" ]; then
  echo "Staging translator-generated changes:"
  printf '%s\n' "${translator_changes}"
  printf '%s\n' "${translator_changes}" | xargs git add --
  git commit -m "chore: update translations"
else
  echo "No translator changes detected. Skipping translation commit."
fi

echo "Building release output..."
npm run build

git add -A .
if git diff --cached --quiet; then
  echo "Error: no changes staged for release after translator/build." >&2
  exit 1
fi

echo "Creating release commit..."
git commit -m "Release: ${VERSION}"

echo "Pushing release branch and tag..."
git push origin main
git tag "v${VERSION}"
git push origin "v${VERSION}"
